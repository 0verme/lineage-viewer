{
  "name": "lineage-viewer",
  "version": "0.1.0",
  "description": "A lightweight, framework-agnostic, embeddable lineage graph viewer.",
  "type": "module",
  "license": "Apache-2.0",
  "sideEffects": [
    "./dist/define.js"
  ],
  "main": "./dist/lineage-viewer.js",
  "module": "./dist/lineage-viewer.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/lineage-viewer.js"
    },
    "./define": {
      "types": "./dist/define.d.ts",
      "import": "./dist/define.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "README.zh-CN.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "dev": "vite",
    "clean": "node scripts/clean.mjs",
    "build": "npm run clean && vite build && tsc -p tsconfig.build.json",
    "build:site": "vite build --config vite.site.config.ts",
    "preview:site": "vite preview --config vite.site.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:site": "playwright test --config playwright.site.config.ts",
    "screenshot:gallery": "node scripts/screenshot-gallery.mjs",
    "screenshot:playground": "node scripts/screenshot-playground.mjs",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm test && npm run build",
    "pack:check": "node scripts/pack-check.mjs",
    "test:package": "node scripts/test-package.mjs",
    "test:release": "vitest run tests/unit/release.test.ts",
    "test:workflows": "node scripts/validate-workflows.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
