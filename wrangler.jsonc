{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "lineage-viewer-demo",
  "main": "./src/worker.ts",
  "compatibility_date": "2026-07-11",
  "cache": {
    "enabled": true,
    "cross_version_cache": false
  },
  "assets": {
    "directory": "./site-dist",
    "binding": "ASSETS",
    "run_worker_first": true
  }
}
